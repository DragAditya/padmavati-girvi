# Gold Rate API (free tier at goldapi.io)
VITE_GOLD_API_KEY=your_goldapi_key_here

# Google OAuth Client ID (for Google Drive backup)
# Create at console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# App version
VITE_APP_VERSION=1.0.0
